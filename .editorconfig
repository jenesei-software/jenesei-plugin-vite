root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
tab_width = 2
max_line_length = 120

[*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,json5,css,scss,html,md,mdx,yml,yaml}]
indent_style = space
indent_size = 2
tab_width = 2
end_of_line = lf
max_line_length = 120

[*.md]
trim_trailing_whitespace = false

[*.{sh,bash,zsh}]
end_of_line = lf
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

[*.{png,jpg,jpeg,gif,webp,ico,pdf,zip,tar,gz,woff,woff2,ttf,eot}]
insert_final_newline = false
trim_trailing_whitespace = false